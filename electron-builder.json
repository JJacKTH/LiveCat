{
  "appId": "com.livecat.app",
  "productName": "LiveCat",
  "directories": {
    "output": "dist_electron"
  },
  "files": [
    "dist/**/*",
    "src/main/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "public/branding/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "LiveCat"
  }
}
